#: usr/local/bin/chili-clonedisk:224
msgid "Bem vindo ao "
msgstr "へようこそ"

#: usr/local/bin/chili-clonedisk:599 usr/local/bin/chili-clonedisk:676
msgid "CLONAR DISCO PARA IMAGEM"
msgstr "ディスクをイメージにクローン作成"

#: usr/local/bin/chili-clonedisk:791
msgid "Selecione o formato da imagem do device"
msgstr "デバイスの画像形式を選択します"

#: usr/local/bin/chili-clonedisk:1385 usr/local/bin/chili-clonedisk:1671
msgid "Clonagem concluída!"
msgstr "クローン作成が完了しました！"

#: usr/local/bin/chili-clonedisk:1539 usr/local/bin/chili-clonedisk:1594
msgid "O disco de DESTINO é menor que o disco de ORIGEM"
msgstr "DESTINATION ディスクは SOURCE ディスクより小さいです"

#: usr/local/bin/chili-clonedisk:1542 usr/local/bin/chili-clonedisk:1597
msgid "Prosseguir?"
msgstr "進む？"

#: usr/local/bin/chili-clonedisk:1677
msgid "Clonar Disco para Disco"
msgstr "ディスクからディスクへのクローン作成"

#: usr/local/bin/chili-clonedisk:1678
msgid "Clonar Disco para Imagem"
msgstr "ディスクをイメージにクローン作成"

#: usr/local/bin/chili-clonedisk:1679
msgid "Clonar Partição para Imagem"
msgstr "パーティションをイメージにクローン作成"

#: usr/local/bin/chili-clonedisk:1680
msgid "Clonar Partição para Partição"
msgstr "パーティションからパーティションへクローンを作成する"

#: usr/local/bin/chili-clonedisk:1681
msgid "Clonar Imagem para Partição"
msgstr "パーティションへのイメージのクローン作成"

#: usr/local/bin/chili-clonedisk:1682
msgid "Gravar ISO para Disco"
msgstr "ISOをディスクに書き込む"

#: usr/local/bin/chili-clonedisk:1683
msgid "Clonar Imagem para Disco"
msgstr "イメージをディスクにクローン作成する"

#: usr/local/bin/chili-clonedisk:1684
msgid "Listar Discos"
msgstr "ディスクのリスト"

#: usr/local/bin/chili-clonedisk:1685
msgid "Clonar Disco para Imagem via Rede (SSH Criptografado)"
msgstr "ネットワーク経由でディスクのクローンをイメージに作成 (暗号化された SSH)"

#: usr/local/bin/chili-clonedisk:1687
msgid "Escolha o formato e compressão da imagem"
msgstr "画像形式と圧縮を選択します"

#: usr/local/bin/chili-clonedisk:1688
msgid "Imagem Bruta Padrão (.img)"
msgstr "標準 RAW 画像 (.img)"

#: usr/local/bin/chili-clonedisk:1689
msgid "Imagem Comprimida de Alta Performance (.img.zst)"
msgstr "高性能圧縮画像 (.img.zst)"

#: usr/local/bin/chili-clonedisk:1691
msgid "Escolha o tipo de clone"
msgstr "クローンの種類を選択してください"

#: usr/local/bin/chili-clonedisk:1692
msgid "Necessário desmontar a partição antes de reparticionar"
msgstr "再パーティション化する前にパーティションをアンマウントする必要がある"

#: usr/local/bin/chili-clonedisk:1693
msgid "** AVISO **"
msgstr "** 知らせ **"

#: usr/local/bin/chili-clonedisk:1694
msgid "Necessário desmontar as partições abaixo antes de prosseguir"
msgstr "続行する前に、以下のパーティションをアンマウントする必要があります"

#: usr/local/bin/chili-clonedisk:1695
msgid "Desmontar ?"
msgstr "分解しますか？"

#: usr/local/bin/chili-clonedisk:1696
msgid "ERRO"
msgstr "エラー"

#: usr/local/bin/chili-clonedisk:1697
msgid "Info disco"
msgstr "ディスク情報"

#: usr/local/bin/chili-clonedisk:1698
msgid "Ok"
msgstr "わかりました"

#: usr/local/bin/chili-clonedisk:1699 usr/local/bin/chili-clonedisk:1729
msgid "DISCO DE DESTINO"
msgstr "宛先ディスク"

#: usr/local/bin/chili-clonedisk:1700
msgid "Escolha o disco ORIGEM"
msgstr "ソースディスクを選択してください"

#: usr/local/bin/chili-clonedisk:1701
msgid "Escolha o disco DESTINO"
msgstr "宛先ディスクを選択してください"

#: usr/local/bin/chili-clonedisk:1702
msgid "Escolha a partição ORIGEM"
msgstr "ORIGIN パーティションを選択します"

#: usr/local/bin/chili-clonedisk:1703
msgid "Escolha a partição DESTINO"
msgstr "DESTINATIONパーティションを選択してください"

#: usr/local/bin/chili-clonedisk:1704
msgid "Sim"
msgstr "はい"

#: usr/local/bin/chili-clonedisk:1705
msgid "Não"
msgstr "いいえ"

#: usr/local/bin/chili-clonedisk:1706
msgid "Seletor de temas da interface (dialog)"
msgstr "インターフェーステーマセレクター（ダイアログ）"

#: usr/local/bin/chili-clonedisk:1708
msgid "Use as teclas"
msgstr "キーを使用する"

#: usr/local/bin/chili-clonedisk:1709
msgid "PARA CIMA"
msgstr "上"

#: usr/local/bin/chili-clonedisk:1710
msgid "e"
msgstr "そして"

#: usr/local/bin/chili-clonedisk:1711
msgid "PARA BAIXO"
msgstr "下"

#: usr/local/bin/chili-clonedisk:1712
msgid "para navegar"
msgstr "ナビゲートする"

#: usr/local/bin/chili-clonedisk:1713
msgid "Use"
msgstr "使用"

#: usr/local/bin/chili-clonedisk:1714
msgid "para alternar entre os botões"
msgstr "ボタンを切り替えるには"

#: usr/local/bin/chili-clonedisk:1715
msgid "para selecionar|aceitar"
msgstr "選択する|受け入れる"

#: usr/local/bin/chili-clonedisk:1722
msgid "Disco ORIGEM e DESTINO não podem ser o mesmo"
msgstr "SOURCE ディスクと DESTINATION ディスクを同じにすることはできません"

#: usr/local/bin/chili-clonedisk:1723
msgid "Formatando partição"
msgstr "パーティションをフォーマット中"

#: usr/local/bin/chili-clonedisk:1724
msgid "Executando clonagem de disco"
msgstr "ディスククローン作成の実行"

#: usr/local/bin/chili-clonedisk:1725
msgid "Selecionar"
msgstr "選択"

#: usr/local/bin/chili-clonedisk:1726
msgid "Sair"
msgstr "外出する"

#: usr/local/bin/chili-clonedisk:1727
msgid "Voltar"
msgstr "戻るには"

#: usr/local/bin/chili-clonedisk:1728
msgid "DISCO DE ORIGEM"
msgstr "ソースディスク"

#: usr/local/bin/chili-clonedisk:1730
msgid "PARTIÇÃO DE ORIGEM"
msgstr "ソースパーティション"

#: usr/local/bin/chili-clonedisk:1731
msgid "PARTIÇÃO DE DESTINO"
msgstr "宛先パーティション"

#: usr/local/bin/chili-clonedisk:1732
msgid "AVISO!"
msgstr "知らせ！"

#: usr/local/bin/chili-clonedisk:1732
msgid "Todos os dados disco/partição de DESTINO abaixo serão perdidos!"
msgstr "以下の宛先ディスク/パーティションのデータはすべて失われます。"

#: usr/local/bin/chili-clonedisk:1733
msgid "Continuar com a clonagem"
msgstr "クローン作成を続行する"

#: usr/local/bin/chili-clonedisk:1745
msgid "Escolha o idioma:"
msgstr "言語を選択してください:"

#: usr/local/bin/chili-clonedisk:1747
msgid "Português"
msgstr "ポルトガル語"

#: usr/local/bin/chili-clonedisk:1748
msgid "Inglês"
msgstr "英語"

#: usr/local/bin/chili-clonedisk:1749
msgid "Alemão"
msgstr "ドイツ語"

#: usr/local/bin/chili-clonedisk:1750
msgid "Francês"
msgstr "フランス語"

