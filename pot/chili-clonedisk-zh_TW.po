msgstr "選擇目標磁碟"

#: usr/local/bin/chili-clonedisk:1766
msgid "Escolha a partição ORIGEM"
msgstr "選擇ORIGIN分區"

#: usr/local/bin/chili-clonedisk:1767
msgid "Escolha a partição DESTINO"
msgstr "選擇目標分割區"

#: usr/local/bin/chili-clonedisk:1768
msgid "Sim"
msgstr "是"

#: usr/local/bin/chili-clonedisk:1769
msgid "Não"
msgstr "不"

