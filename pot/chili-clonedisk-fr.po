#: usr/local/bin/chili-clonedisk:224
msgid "Bem vindo ao "
msgstr "Bienvenue à"

#: usr/local/bin/chili-clonedisk:599 usr/local/bin/chili-clonedisk:676
msgid "CLONAR DISCO PARA IMAGEM"
msgstr "Cloner le disque vers l'image"

#: usr/local/bin/chili-clonedisk:791
msgid "Selecione o formato da imagem do device"
msgstr "Sélectionnez le format d'image de l'appareil"

#: usr/local/bin/chili-clonedisk:1374
msgid "O utilitário 'qemu-img' não foi encontrado no sistema!"
msgstr "L'utilitaire 'qemu-img' n'a pas été trouvé sur le système !"

#: usr/local/bin/chili-clonedisk:1374
msgid "Instale o pacote qemu-utils para restaurar arquivos .qcow2."
msgstr "Installez le package qemu-utils pour restaurer les fichiers .qcow2."

#: usr/local/bin/chili-clonedisk:1412
msgid "Falha ao clonar a imagem QCOW2"
msgstr "Échec du clonage de l'image QCOW2"

#: usr/local/bin/chili-clonedisk:1415
msgid "Erro retornado pelo qemu-img:"
msgstr "Erreur renvoyée par qemu-img :"

#: usr/local/bin/chili-clonedisk:1448 usr/local/bin/chili-clonedisk:1735
msgid "Clonagem concluída!"
msgstr "Clonage terminé !"

#: usr/local/bin/chili-clonedisk:1603 usr/local/bin/chili-clonedisk:1658
msgid "O disco de DESTINO é menor que o disco de ORIGEM"
msgstr "Le disque DESTINATION est plus petit que le disque SOURCE"

#: usr/local/bin/chili-clonedisk:1606 usr/local/bin/chili-clonedisk:1661
msgid "Prosseguir?"
msgstr "Procéder?"

#: usr/local/bin/chili-clonedisk:1741
msgid "Clonar Disco para Disco"
msgstr "Cloner un disque sur un disque"

#: usr/local/bin/chili-clonedisk:1742
msgid "Clonar Disco para Imagem"
msgstr "Cloner le disque vers l'image"

#: usr/local/bin/chili-clonedisk:1743
msgid "Clonar Partição para Imagem"
msgstr "Cloner une partition dans une image"

#: usr/local/bin/chili-clonedisk:1744
msgid "Clonar Partição para Partição"
msgstr "Cloner une partition sur une partition"

#: usr/local/bin/chili-clonedisk:1745
msgid "Clonar Imagem para Partição"
msgstr "Cloner une image sur une partition"

#: usr/local/bin/chili-clonedisk:1746
msgid "Gravar ISO para Disco"
msgstr "Graver l'ISO sur un disque"

#: usr/local/bin/chili-clonedisk:1747
msgid "Clonar Imagem para Disco"
msgstr "Cloner l'image sur le disque"

#: usr/local/bin/chili-clonedisk:1748
msgid "Listar Discos"
msgstr "Liste des disques"

