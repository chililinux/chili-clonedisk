#: usr/bin/chili-clonedisk:181
msgid "Bem vindo ao "
msgstr "Bienvenue à"

#: usr/bin/chili-clonedisk:578
msgid "CLONAR DISCO PARA IMAGEM"
msgstr "Cloner le disque vers l'image"

#: usr/bin/chili-clonedisk:639
msgid "Selecione o formato da imagem do device"
msgstr "Sélectionnez le format d'image de l'appareil"

#: usr/bin/chili-clonedisk:1167 usr/bin/chili-clonedisk:1222
msgid "O disco de DESTINO é menor que o disco de ORIGEM"
msgstr "Le disque DESTINATION est plus petit que le disque SOURCE"

#: usr/bin/chili-clonedisk:1170 usr/bin/chili-clonedisk:1225
msgid "Prosseguir?"
msgstr "Procéder?"

#: usr/bin/chili-clonedisk:1299
msgid "Clonagem concluída!"
msgstr "Clonage terminé !"

#: usr/bin/chili-clonedisk:1305
msgid "Clonar Disco para Disco"
msgstr "Cloner un disque sur un disque"

#: usr/bin/chili-clonedisk:1306
msgid "Clonar Disco para Imagem"
msgstr "Cloner le disque vers l'image"

#: usr/bin/chili-clonedisk:1307
msgid "Clonar Partição para Imagem"
msgstr "Cloner une partition dans une image"

#: usr/bin/chili-clonedisk:1308
msgid "Clonar Partição para Partição"
msgstr "Cloner une partition sur une partition"

#: usr/bin/chili-clonedisk:1309
msgid "Clonar Imagem para Partição"
msgstr "Cloner une image sur une partition"

#: usr/bin/chili-clonedisk:1310
msgid "Gravar ISO para Disco"
msgstr "Graver l'ISO sur un disque"

#: usr/bin/chili-clonedisk:1311
msgid "Listar Discos"
msgstr "Liste des disques"

#: usr/bin/chili-clonedisk:1313
msgid "Escolha o tipo de clone"
msgstr "Choisissez le type de clone"

#: usr/bin/chili-clonedisk:1314
msgid "Necessário desmontar a partição antes de reparticionar"
msgstr "Besoin de démonter la partition avant de repartitionner"

#: usr/bin/chili-clonedisk:1315
msgid "** AVISO **"
msgstr "** AVIS **"

#: usr/bin/chili-clonedisk:1316
msgid "Necessário desmontar as partições abaixo antes de prosseguir"
msgstr "Vous devez démonter les partitions ci-dessous avant de continuer"

#: usr/bin/chili-clonedisk:1317
msgid "Desmontar ?"
msgstr "Démonter?"

#: usr/bin/chili-clonedisk:1318
msgid "ERRO"
msgstr "ERREUR"

#: usr/bin/chili-clonedisk:1319
msgid "Info disco"
msgstr "Informations sur le disque"

#: usr/bin/chili-clonedisk:1320
msgid "Ok"
msgstr "D'accord"

#: usr/bin/chili-clonedisk:1321 usr/bin/chili-clonedisk:1346
msgid "DISCO DE DESTINO"
msgstr "DISQUE DE DESTINATION"

#: usr/bin/chili-clonedisk:1322
msgid "Escolha o disco ORIGEM"
msgstr "Choisissez le disque SOURCE"

#: usr/bin/chili-clonedisk:1323
msgid "Escolha o disco DESTINO"
msgstr "Choisissez le disque DESTINATION"

#: usr/bin/chili-clonedisk:1324
msgid "Escolha a partição ORIGEM"
msgstr "Choisissez la partition ORIGINE"

#: usr/bin/chili-clonedisk:1325
msgid "Escolha a partição DESTINO"
msgstr "Choisissez la partition DESTINATION"

#: usr/bin/chili-clonedisk:1326
msgid "Sim"
msgstr "Oui"

#: usr/bin/chili-clonedisk:1327
msgid "Não"
msgstr "Non"

#: usr/bin/chili-clonedisk:1329
msgid "Use as teclas"
msgstr "Utilisez les clés"

#: usr/bin/chili-clonedisk:1330
msgid "PARA CIMA"
msgstr "EN HAUT"

#: usr/bin/chili-clonedisk:1331
msgid "e"
msgstr "et"

#: usr/bin/chili-clonedisk:1332
msgid "PARA BAIXO"
msgstr "VERS LE BAS"

#: usr/bin/chili-clonedisk:1333
msgid "para navegar"
msgstr "naviguer"

#: usr/bin/chili-clonedisk:1334
msgid "Use"
msgstr "Utiliser"

#: usr/bin/chili-clonedisk:1335
msgid "para alternar entre os botões"
msgstr "pour basculer entre les boutons"

#: usr/bin/chili-clonedisk:1336
msgid "para selecionar"
msgstr "sélectionner"

#: usr/bin/chili-clonedisk:1339
msgid "Disco ORIGEM e DESTINO não podem ser o mesmo"
msgstr "Les disques SOURCE et DESTINATION ne peuvent pas être identiques"

#: usr/bin/chili-clonedisk:1340
msgid "Formatando partição"
msgstr "Formatage d'une partition"

#: usr/bin/chili-clonedisk:1341
msgid "Executando clonagem de disco"
msgstr "Effectuer un clonage de disque"

#: usr/bin/chili-clonedisk:1342
msgid "Selecionar"
msgstr "Sélectionner"

#: usr/bin/chili-clonedisk:1343
msgid "Sair"
msgstr "Pour sortir"

#: usr/bin/chili-clonedisk:1344
msgid "Voltar"
msgstr "Pour revenir"

#: usr/bin/chili-clonedisk:1345
msgid "DISCO DE ORIGEM"
msgstr "DISQUE SOURCE"

#: usr/bin/chili-clonedisk:1347
msgid "PARTIÇÃO DE ORIGEM"
msgstr "PARTITION SOURCE"

#: usr/bin/chili-clonedisk:1348
msgid "PARTIÇÃO DE DESTINO"
msgstr "PARTITION DE DESTINATION"

#: usr/bin/chili-clonedisk:1349
msgid "AVISO!"
msgstr "AVIS!"

#: usr/bin/chili-clonedisk:1349
msgid "Todos os dados disco/partição de DESTINO abaixo serão perdidos!"
msgstr "Toutes les données du disque/partition DESTINATION ci-dessous seront perdues !"

#: usr/bin/chili-clonedisk:1350
msgid "Continuar com a clonagem"
msgstr "Continuer le clonage"

#: usr/bin/chili-clonedisk:1362
msgid "Escolha o idioma:"
msgstr "Choisissez la langue :"

#: usr/bin/chili-clonedisk:1364
msgid "Português"
msgstr "portugais"

#: usr/bin/chili-clonedisk:1365
msgid "Inglês"
msgstr "Anglais"

#: usr/bin/chili-clonedisk:1366
msgid "Alemão"
msgstr "Allemand"

#: usr/bin/chili-clonedisk:1367
msgid "Francês"
msgstr "Français"

