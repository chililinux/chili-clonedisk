init() {
	while true; do
		i18=$(${DIALOG} \
			--stdout \
			--clear \
			--backtitle "$ccabec" \
			--title "${welcome}${xapp}" \
			--ok-label "${cmsg_Ok}" \
			--cancel-label "${cmsg_Sair}" \
			--menu "\n$(gettext "Escolha o idioma:")" \
			0 80 0 \
			0 "$(gettext "Português")" \
			1 "$(gettext "Inglês")" \
			2 "$(gettext "Alemão")" \
			3 "$(gettext "Francês")")

		exit_status=$?
		case $exit_status in
		"$D_ESC" | "$D_CANCEL")
			exit 0
			;;
		esac
		LC_DEFAULT=$i18
		sh_choose_clone_type
	done
}

