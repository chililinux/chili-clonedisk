	${DIALOG} \
		--colors \
		--title "$1" \
		--no-collapse \
		--cr-wrap \
		--keep-tite \
		--backtitle "$ccabec" \
		--msgbox "\Z2$2\n\Z1$3\n\Z3$4\n\Z4$5\n\Z5$6" \
		0 0
}

