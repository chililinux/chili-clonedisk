}

sh_usage() {
	printf '%s\n' "${cyan}$(gettext "Comandos mais usados:")"
	printf '%s\n' "${red}	-h  ${reset}- $(gettext "exibir esta ajuda e sair")"
	printf '%s\n' "${red}	-v  ${reset}- $(gettext "mostrar versão")"
	printf '%s\n' "${red}	-c  ${reset}- $(gettext "suprime colorização da saída")"
}

if [[ $1 = "-v" || $1 = "--version" || $1 = "-V" ]]; then
	sh_logo
	exit 0
fi

sh_checkrootOLD() {
	[[ $1 = "-Qq" ]] && return
	if [ "$(id -u)" != "0" ]; then
		printf "${red}%s\n" "$(gettext "erro: Você não pode executar esta operação a menos que seja root!")"
		exit 1
	fi
}

sh_checkroot() {
	if [[ "$(id -u)" != "0" ]]; then
		elevate_to_root "$@"
	fi
	ccabec+=' [root]'
}

log_err() {
	printf " %b %s\\n" "${CROSS}" "${*}"
}

elevate_to_root() {
	log_err "This script must be run as root. Elevating privileges..."

	# Tenta usar sudo primeiro (caso esteja configurado)
	if command -v sudo >/dev/null 2>&1; then
		exec sudo bash "$0" "$@"
	fi

	# Se sudo falhar, tenta su
	if command -v su >/dev/null 2>&1; then
		exec su -c "$0 $*"
	fi
	die "Error: Unable to elevate privileges. Run manually as root."
}

DOT() {
	printf "%s" "${blue}:: ${reset}"
}

die() {
	local msg=$1
	shift
	printf "%-75s\n" "$(DOT)${bold}${red}$msg${reset}" >&2
	exit 1
}

log_msg() {
	local retval="${PIPESTATUS[0]}"

	if [[ $retval -eq 0 ]]; then
		printf " %b %s\\n" "${TICK}" "${*}"
	else
		printf " %b %s\\n" "${CROSS}" "${*}"
	fi
}

run_dialog_stream() {
	local title="$1"
	shift
	stdbuf -oL -eL "$@" 2>&1 |
		dialog \
			--backtitle "$ccabec" \
			--progressbox "$title" 20 70
	local status=${PIPESTATUS[0]}
	return "$status"
}

sh_setup() {
	local DISTRO=$(detect_distro)
	msg "$_APP_" "Instalando necessários pacotes"

	case "$DISTRO" in
	void | voidlinux | void-live)
		if ! run_dialog_stream "Instalando pacoates no ${DISTRO^^}" \
			xbps-install -Sy "${PACKAGEDEP[@]}"; then
			die "[ERRO] Falha ao instalar pacotes."
		fi
		;;
	chili | chililinux | arch | manjaro | biglinux)
		if ! run_dialog_stream "Instalando pacoates no ${DISTRO^^}" \
			pacman -S --neeeded --quiet --noconfirm "${PACKAGEDEP[@]}"; then
			die "[ERRO] Falha ao instalar pacotes."
		fi
		;;
	manjaro) : ;;
	debian) : ;;
	ubuntu) : ;;
	ubuntu) : ;;
	fedora) : ;;
	endeavouros) : ;;
	*)
		echo "Outra distro: $DISTRO"
		;;
	esac
}

sh_checkDependencies() {
	local aBlock_files=()
	local d
	local errorFound=false
	declare -a missing

	for d in "${DEPENDENCIES[@]}"; do
		if ! command -v "$d" &>/dev/null; then
			log_err "Check: ${red}ERROR${reset}: $(gettext "Não foi possível encontrar o comando") ${cyan}'$d'${reset} -> $(gettext "instalar pacote") ${cyan}"${PACKAGEDEP[$d]}"${reset}"
			missing+=("$d")
			errorFound=true
		else
			#     log_msg "Check: ${cyan}$d"
			:
		fi
	done

	if $errorFound; then
		replicate '='
		echo "${yellow}             $(gettext "IMPOSSÍVEL CONTINUAR")"
		echo "${black}$(gettext "Este script precisa dos comandos listados acima")"
		echo "${black}$(gettext "Instale-os e/ou verifique se eles estão em seu") ${red}\$PATH${reset}"
		replicate '='
		#die $(gettext "Abortando...")
		if readconf "Deseja instalar os pacotes e suprir os aplicativos necessários ?"; then
			sh_setup
		else
			exit 1
		fi
	fi
}
export -f sh_checkDependencies

sh_display() {
	if [[ "$(tput cols)" -lt 80 ]] || [[ "$(tput lines)" -lt 24 ]]; then
		dialog --backtitle "$ccabec" \
			--title "$(gettext "TERMINAL MUITO PEQUENO")" \
			--msgbox "\n\
$(gettext "Antes de continuar, redimensione seu terminal\npara que ele meça pelo menos 80 x 24 caracteres")\n\
$(gettext "Caso contrário, você não poderá usar as ferramentas de partição de disco")" 11 68
	fi
}

sh_execute_iso2usb() {
	if command -v chili-iso2usb >/dev/null; then
		bash chili-iso2usb
	else
		info "Erro: O utilitário 'chili-iso2usb' não está instalado no sistema."
	fi
	return
}

sh_choose_compression_type() {
	while true; do
		compress_type=$(
			${DIALOG} \
				--clear \
				--stdout \
				--aspect 20 \
				--backtitle "$ccabec" \
				--colors \
				--title "FORMATO DA IMAGEM" \
				--ok-label "${cmsg_Select}" \
				--cancel-label "${cmsg_Sair}" \
				--menu "${cmsg_LABEL}\n\n${YELLOW}${cmsg_Escolha_o_Formato_da_Imagem}:${RESET}" \
				10 80 0 \
				0 "${cmsg_Imagem_Bruta_Padrao}" \
				1 "${cmsg_Imagem_Comprimida_Zstd}"
		)

		exit_status=$?
		case $exit_status in
		"$D_ESC" | "$D_CANCEL")
			return 255
			;;
		esac

		# Se o usuário escolheu Zstd, mas não tem o binário instalado no sistema
		if [[ "$compress_type" -eq 1 ]] && ! command -v zstd >/dev/null 2>&1; then
			info "Erro: O utilitário 'zstd' não está instalado no sistema para compressão."
			continue
		fi

		echo "$compress_type"
		return 0
	done
}

sh_run_binary() {
	local binary="${1}"
	local lang="${2}"
	local grafic="${3}"

	if [[ -n $(command -v "${binary}") || -n $(command -v ./"${binary}") ]]; then
		bash "${binary}" "$lang" "${grafic}"
		return 0
	fi

	msg "INFO" "$(log_info_msg "$(gettext "Aguarde...") ${cmsg_Gerando} test with "${binary}" ${xurl}")"
	evaluate_retval 1 "$err_not_fatal"
	info "${WHITE}${REVERSE}${binary}${RESET}" \
		"\n\n${RED}✗ $(gettext "binário não foi localizado no") ${YELLOW}\$PATH" \
		"\n${RED}✗ $(gettext "binário não foi localizado na pasta local:") ${YELLOW}$PWD${RESET}" \
		"${YELLOW}\n➡ $(gettext "DICA: instale o pacote chili-utils")"
	return 1
}

sh_get_local_ip() {
	local local_ip
	local_ip=$(ip route get 1.1.1.1 2>/dev/null | awk '{print $7; exit}')
	if [[ -z "$local_ip" ]]; then
		echo "192.168.1.100"
	else
		echo "$local_ip"
	fi
}

sh_menu_network_ssh() {
	local source="$1"
	local txtNetworkData

	local local_ip
	local_ip=$(sh_get_local_ip)

	local base_ip="${local_ip%.*}"

	local ssh_user="root"
	local ssh_ip="${base_ip}.100"
	local ssh_porta="22"
	local ssh_password=""
	local use_sshpass=0
	local format_type=""

	while true; do
		# 1. Chama a nova função modular para obter o formato desejado
		format_type=$(sh_get_network_format)

		if [[ -z "$format_type" ]]; then
			return 1
		fi

		# 2. Define dinamicamente o arquivo padrão com base no formato retornado
		local ssh_outfile="/mnt/backup/${DEVICE_SOURCE//\//_}_remote.img.${format_type}"
		if [[ "$format_type" == "img" ]]; then
			ssh_outfile="/mnt/backup/${DEVICE_SOURCE//\//_}_remote.img"
		fi

		# 3. Abre o formulário com o nome do arquivo já preenchido com a extensão correta
		exec 3>&1
		txtNetworkData=$(${DIALOG} \
			--backtitle "$ccabec" \
			--title "** $(gettext "CLONAGEM REMOTA VIA SSH") **" \
			--ok-label "${cmsg_Select}" \
			--cancel-label "${cmsg_button_voltar}" \
			--colors \
			--insecure \
			--mixedform "$(gettext "Entre com as credenciais do servidor SSH de destino e caminho:")" \
			14 90 0 \
			"$(gettext "Usuário Remoto  :")" 1 1 "$ssh_user" 1 20 20 0 0 \
			"$(gettext "IP do Servidor  :")" 2 1 "$ssh_ip" 2 20 30 0 0 \
			"$(gettext "Porta SSH       :")" 3 1 "$ssh_porta" 3 20 10 0 0 \
			"$(gettext "Arquivo Destino :")" 4 1 "$ssh_outfile" 4 20 60 0 0 \
			2>&1 1>&3)

		local exit_status=$?
		exec 3>&-

		case $exit_status in
		1 | 255)
			# Se voltar no formulário, retorna para a tela de escolha de formato
			continue
			;;
		0)
			mapfile -t aNetData <<<"$txtNetworkData"
			ssh_user="${aNetData[0]}"
			ssh_ip="${aNetData[1]}"
			ssh_porta="${aNetData[2]}"
			ssh_outfile="${aNetData[3]}"

			if [[ -z "$ssh_user" || -z "$ssh_ip" || -z "$ssh_outfile" ]]; then
				conf "*** SSH CONFIG ***" "\n$(gettext "Todos os campos devem ser preenchidos! Tente novamente.")\n"
				continue
			fi

			${DIALOG} --title "$(gettext "TESTANDO CONEXÃO")" --infobox "\n$(gettext "Tentando conexão via Chave Pública em") $ssh_ip..." 5 60
			if ssh -p "$ssh_porta" -o ConnectTimeout=3 -o BatchMode=yes -o StrictHostKeyChecking=no "$ssh_user@$ssh_ip" "true" >/dev/null 2>&1; then
				use_sshpass=0
			else
				if ! command -v sshpass >/dev/null 2>&1; then
					conf "*** ERRO DE REQUISITO ***" "${RED}$(gettext "O utilitário 'sshpass' não foi encontrado no sistema!")${RESET}\n\n$(gettext "Instale o pacote 'sshpass' ou configure chaves públicas para habilitar a clonagem via rede.")"
					continue
				fi

				ssh_password=$(${DIALOG} --backtitle "$ccabec" --title "$(gettext "AUTENTICAÇÃO REQUERIDA")" --clear --insecure --passwordbox "$(gettext "A conexão direta por chave falhou.\nDigite a senha para") $ssh_user@$ssh_ip:" 10 60 2>&1 >/dev/tty)
				if [[ $? -ne 0 || -z "$ssh_password" ]]; then
					continue
				fi

				${DIALOG} --title "$(gettext "TESTANDO SENHA")" --infobox "\n$(gettext "Validando senha no servidor remoto...")" 5 60
				if ! sshpass -p "$ssh_password" ssh -p "$ssh_porta" -o ConnectTimeout=5 -o StrictHostKeyChecking=no "$ssh_user@$ssh_ip" "true" >/dev/null 2>&1; then
					conf "*** ERRO DE AUTENTICAÇÃO ***" "${RED}$(gettext "Senha incorreta ou acesso rejeitado pelo servidor remoto!")${RESET}\n$(gettext "Verifique suas credenciais e tente novamente.")"
					continue
				fi
				use_sshpass=1
			fi

			sh_make_clone_network_ssh "$source" "$ssh_user" "$ssh_ip" "$ssh_porta" "$ssh_outfile" "$use_sshpass" "$ssh_password" "$format_type"
			return $?
			;;
		esac
	done
}

sh_get_network_format() {
	local format_type
	format_type=$(${DIALOG} \
		--clear \
		--stdout \
		--backtitle "$ccabec" \
		--title "$(gettext "FORMATO DE COMPRESSÃO")" \
		--ok-label "${cmsg_Select}" \
		--cancel-label "${cmsg_button_voltar}" \
		--menu "$(gettext "Escolha o formato de saída para a imagem remota:")" \
		12 60 0 \
		"zst" "Zstandard (Otimizado/Adaptativo)" \
		"gz" "Gzip (Compatibilidade)" \
		"xz" "XZ / LZMA (Máxima Compressão)" \
		"img" "Sem compressão (Imagem Raw / bruto)" \
		2>&1)

	if [[ $? -eq 0 && -n "$format_type" ]]; then
		echo "$format_type"
	else
		echo ""
	fi
}

sh_make_clone_network_ssh() {
	local source="$1"
	local ssh_user="$2"
	local ssh_ip="$3"
	local ssh_porta="$4"
	local ssh_outfile="$5"
	local use_sshpass="$6"
	local ssh_password="$7"
	local format_type="$8"
	local -i nchoice
	set -o pipefail

	if conf "${cwarning}" \
		"${cmsg_disco_origem[LC_DEFAULT]}: ${GREEN}$DEVICE_SOURCE | $SIZE_SOURCE | $MODEL_SOURCE${RESET}\n\
$(gettext "SERVIDOR DESTINO :") ${YELLOW}$ssh_user@$ssh_ip:$ssh_porta${RESET}\n\
$(gettext "ARQUIVO REMOTO   :") ${RED}$ssh_outfile\n\n" \
		"${BOLD}${YELLOW}$(gettext "Confirmar o início da clonagem criptografada via rede?")${RESET}\n"; then

		sh_start_time_elapsed
		mensagem "$(gettext "Iniciando transmissão de") $source $(gettext "para") $ssh_ip:$ssh_outfile"

		local src_size
		if [[ -b "$source" ]]; then
			src_size=$(sudo blockdev --getsize64 "$source")
		else
			src_size=$(stat -c%s "$source")
		fi

		SECTOR_SIZE=$(blockdev --getss "$source")

		# Mapeamento limpo sem o bzip2
		local compress_cmd="cat"
		local use_custom_pipeline=0

		case "$format_type" in
		zst) compress_cmd="zstd --adapt=min=1,max=9 -T2" ;;
		gz) compress_cmd="gzip -c" ;;
		xz) compress_cmd="xz -c -T2" ;;
		img) compress_cmd="cat" ;;
		qcow2) use_custom_pipeline=1 ;;
		*) compress_cmd="zstd --adapt=min=1,max=9 -T2" ;;
		esac

		local remote_dir
		remote_dir=$(dirname "$ssh_outfile")

		${DIALOG} --title "$(gettext "PREPARANDO DESTINO")" --infobox "\n$(gettext "Garantindo que o diretório remoto existe...")" 5 60
		local mkdir_cmd="ssh -p '$ssh_porta' -o StrictHostKeyChecking=no '$ssh_user@$ssh_ip' 'mkdir -p \"$remote_dir\"'"
		if [[ "$use_sshpass" -eq 1 ]]; then
			mkdir_cmd="sshpass -p '$ssh_password' $mkdir_cmd"
		fi

		if ! eval "$mkdir_cmd" >/dev/null 2>&1; then
			conf "*** ERRO DE DIRETÓRIO ***" "${RED}$(gettext "Falha ao criar o diretório remoto:")${RESET} $remote_dir\n$(gettext "Verifique as permissões de escrita do usuário no destino.")"
			return 1
		fi

		local fifo_tmp="/tmp/clonereder_fifo_$$"
		rm -f "$fifo_tmp"
		mkfifo "$fifo_tmp"

		local ssh_cmd="ssh -p '$ssh_porta' -o StrictHostKeyChecking=no '$ssh_user@$ssh_ip' 'cat > \"$ssh_outfile\"'"

		if [[ "$use_sshpass" -eq 1 ]]; then
			ssh_cmd="sshpass -p '$ssh_password' $ssh_cmd"
		fi

		if [[ "$use_custom_pipeline" -eq 1 ]]; then
			qemu-img convert -O qcow2 "$fifo_tmp" /dev/stdout | eval "$ssh_cmd" 2>/dev/null &
		else
			(cat "$fifo_tmp" | $compress_cmd) | eval "$ssh_cmd" 2>/dev/null &
		fi
		local network_pid=$!

		(
			pv --numeric --size "$src_size" "$source" >"$fifo_tmp"
		) 2>&1 |
			${DIALOG} \
				--title "$(gettext "CLONAGEM REMOTA EM ANDAMENTO")" \
				--colors \
				--gauge \
				"${BOLD}${WHITE}${REVERSE}$(gettext "Processando: pv → conversor/compressor → SSH → Rede")${RESET}\n\n\
${cmsg_disco_origem[LC_DEFAULT]}: ${YELLOW}$DEVICE_SOURCE ($SIZE_SOURCE)${RESET}\n\
$(gettext "DESTINO REMOTO :") ${RED}$ssh_ip:$ssh_outfile${RESET}" \
				11 100 0

		nchoice=${PIPESTATUS[1]}

		wait "$network_pid"
		rm -f "$fifo_tmp"

		sh_end_time_elapsed

		if [[ $nchoice -eq 0 ]]; then
			local remote_size="N/A"
			local size_cmd="ssh -p '$ssh_porta' -o StrictHostKeyChecking=no '$ssh_user@$ssh_ip' 'du -sh \"$ssh_outfile\" 2>/dev/null | awk \"{print \\\$1}\"'"
			if [[ "$use_sshpass" -eq 1 ]]; then
				size_cmd="sshpass -p '$ssh_password' $size_cmd"
			fi
			remote_size=$(eval "$size_cmd")
			[[ -z "$remote_size" ]] && remote_size="Unknown"

			display_result \
				"$(gettext "Resumo da Operação de Rede")" \
				"${BOLD}${GREEN}${REVERSE}$(gettext "Clonagem Remota Concluída com Sucesso!")${RESET}\n\n" \
				"$(gettext "Origem Local     :") ${BOLD}${WHITE}$source${RESET}\n" \
				"$(gettext "Destino Remoto   :") ${BOLD}${WHITE}$ssh_user@$ssh_ip:$ssh_outfile${RESET}\n" \
				"$(gettext "Tamanho Remoto   :") ${BOLD}${YELLOW}$remote_size${RESET}\n\n" \
				"$(gettext "Start Date time  :") ${BOLD}${BLUE}$start_datetime${RESET}\n" \
				"$(gettext "Finish Date Time :") ${BOLD}${BLUE}$end_datetime${RESET}\n" \
				"$(gettext "Time elapsed     :") ${BOLD}${GREEN}($(sh_time_elapsed))${RESET}\n"
		fi

		return $nchoice
	fi
	return 1
}

sh_clone_network_ssh() {
	local localtitle="$(gettext "SELECIONE O DISCO DE ORIGEM PARA REDE")"
	local diskselected=""

	source=$(sh_list_disk "${localtitle}" "${diskselected}")

	if [[ -n "$source" ]]; then
		sh_disk_info
		DEVICE_SOURCE="$source"
		MODEL_SOURCE="$(sh_splitarray "${AARRAY_DSK_DEVICES[$source]}" "$DSK_MODEL")"
		SIZE_SOURCE="$(sh_splitarray "${AARRAY_DSK_DEVICES[$source]}" "$DSK_SIZE")"

		sh_menu_network_ssh "$source"
	fi
}

# --keep-tite \
sh_choose_clone_type() {
	while true; do
		clone_type=$(
			${DIALOG} \
				--clear \
				--stdout \
				--aspect 20 \
				--backtitle "$ccabec" \
				--colors \
				--title "$(gettext "MENU PRINCIPAL")" \
				--ok-label "${cmsg_Select}" \
				--cancel-label "${cmsg_Sair}" \
				--menu "${cmsg_LABEL}\n\n${cmsg_Escolha_o_tipo_de_clone}:" \
				10 80 0 \
				0 "${cmsg_Clonar_Disco_para_Disco}" \
				1 "${cmsg_Clonar_Disco_para_Imagem}" \
				2 "${cmsg_Clonar_via_Rede}" \
				3 "${cmsg_Clonar_Particao_para_Imagem}" \
				4 "${cmsg_Clonar_Particao_para_Particao}" \
				5 "${cmsg_Clonar_Imagem_para_Particao}" \
				6 "${cmsg_Clonar_Imagem_para_Disco}" \
				7 "${cmsg_Gravar_ISO_para_Disco}" \
				8 "${cmsg_Listar_Discos}" \
				9 "${cmsg_Tema}"
		)

		exit_status=$?
		case $exit_status in
		"$D_ESC" | "$D_CANCEL")
			exit 0
			;;
		esac
		case $clone_type in
		0) sh_clone_disk_to_disk ;;
		1) sh_clone_disk_to_image ;;
		2) sh_clone_network_ssh ;;
		3) sh_clone_part_to_image ;;
		4) sh_clone_part_to_part ;;
		5) sh_clone_image_to_part ;;
		6) sh_clone_image_to_disk ;;
		7) sh_execute_iso2usb ;;
		8) sh_list_disk ;;
		9) sh_run_binary 'chili-dialog-theme-selector' ;;
		esac
	done
}

